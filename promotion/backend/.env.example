# ========================================
# 推广返佣系统 - 环境变量配置示例
# 复制此文件为 .env 并修改对应值
# ========================================

# ---------- 环境 ----------
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------- 服务端口 ----------
PROMOTION_PORT=8092

# ---------- 数据库（MySQL） ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=xianyu_data

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- JWT ----------
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ---------- CORS ----------
# 多个源用逗号分隔，或设为 * 允许所有
CORS_ORIGINS=*

# ---------- 静态文件 ----------
STATIC_DIR=static
